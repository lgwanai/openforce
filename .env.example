# OpenForce Configuration Example
# Copy this file to .env and fill in your values

# External Tools
OPENFORCE_BAIDU_SEARCH_SCRIPT=/path/to/your/search.py
OPENFORCE_AGENT_BROWSER_PATH=/usr/local/bin/agent-browser
OPENFORCE_PLAYWRIGHT_CACHE_DIR=/tmp/Library/Caches/ms-playwright

# Security Settings
OPENFORCE_SECURITY_APPROVAL_SECRET_KEY=your-secret-key-here
