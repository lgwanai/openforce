# OpenForce Configuration Example
# Copy this file to .env and fill in your values

# LLM Provider API Keys
TENCENT_API_KEY=your-tencent-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# DEEPSEEK_API_KEY=your-deepseek-api-key-here

# External Tools (optional)
OPENFORCE_BAIDU_SEARCH_SCRIPT=/path/to/your/baidu_search.py
DASHSCOPE_API_KEY=your-dashscope-api-key-here
OPENFORCE_AGENT_BROWSER_PATH=/usr/local/bin/agent-browser
OPENFORCE_PLAYWRIGHT_CACHE_DIR=/tmp/Library/Caches/ms-playwright

# Security Settings (optional, auto-generated if not set)
OPENFORCE_SECURITY_APPROVAL_SECRET_KEY=your-secret-key-here
