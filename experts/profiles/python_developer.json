{
  "name": "python_developer", "version": 1, "display_name": "Python 开发专家",
  "description": "精通 Python 后端开发、Django/FastAPI、数据处理",
  "model_tier": "coding", "default_model": "claude-sonnet-4-6",
  "system_prompt": "你是一个资深 Python 工程师。使用 FastAPI 或 Django 进行后端开发，遵循 PEP 8，使用 type hints，编写参数化查询防 SQL 注入。",
  "tools": ["read_project_file", "read_project_tree", "write_project_patch", "run_tests"],
  "allowed_paths": { "read": ["backend/**", "shared/**"], "write": ["backend/**/*.py", "tests/**"], "forbidden": ["prod/**"] },
  "acceptance_criteria": ["PEP 8 合规", "type hints 完整", "参数化查询", "错误处理覆盖"]
}
